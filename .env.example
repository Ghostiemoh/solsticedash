# ====================================
# Solstice — Environment Variables
# ====================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Solana RPC ────────────────────────
# Primary RPC endpoint (Helius recommended for free tier + Yellowstone gRPC)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Backup RPC endpoint (optional, for failover)
SOLANA_RPC_BACKUP_URL=https://api.mainnet-beta.solana.com
# Devnet RPC (for development/testing)
SOLANA_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Network: "mainnet-beta" | "devnet"
SOLANA_NETWORK=devnet

# ─── Yellowstone gRPC ─────────────────
# Yellowstone gRPC endpoint (Helius provides this)
YELLOWSTONE_GRPC_URL=YOUR_GRPC_ENDPOINT
# Yellowstone auth token
YELLOWSTONE_GRPC_TOKEN=YOUR_GRPC_TOKEN

# ─── Wallet ───────────────────────────
# Base58-encoded private key (for signing transactions)
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
# OR path to keypair JSON file
# WALLET_KEYPAIR_PATH=./keypair.json

# ─── Jito ─────────────────────────────
# Jito Block Engine endpoint
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Default tip amount in lamports (1000 = 0.000001 SOL)
JITO_DEFAULT_TIP_LAMPORTS=10000
# Maximum tip in lamports
JITO_MAX_TIP_LAMPORTS=1000000

# ─── AI (Gemini) ──────────────────────
# Gemini API key for the AI Decision Engine
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Model to use (gemini-2.0-flash recommended for speed)
GEMINI_MODEL=gemini-2.0-flash
# Max tokens for AI responses
GEMINI_MAX_TOKENS=1024

# ─── Database ─────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://solstice:solstice_password@localhost:5432/solstice?schema=public

# ─── Redis ────────────────────────────
# Redis connection URL (for BullMQ queues + caching)
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────
# Backend server port
PORT=3001
# WebSocket server port (same as backend for Fastify)
WS_PORT=3001
# Dashboard port
DASHBOARD_PORT=3000
# Host binding
HOST=0.0.0.0

# ─── Observability ────────────────────
# Log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
LOG_LEVEL=info
# Enable Prometheus metrics
METRICS_ENABLED=true
# Metrics endpoint path
METRICS_PATH=/metrics

# ─── Environment ──────────────────────
NODE_ENV=development

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "noImplicitAny": false,
    "paths": {
      "@solstice/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/__tests__", "src/**/*.test.ts", "vitest.config.ts", "vitest.setup.ts"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
